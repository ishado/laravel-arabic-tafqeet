{
  "name": "alkoumi/laravel-arabic-tafqeet",
  "description": "a package to translate money numbers to our Amazing 💝 Arabic language TAFQEET . to look like [فقط تسعمائة ألف ريال و أربعة و ثلاثون هللة لاغير]",
  "keywords": [
    "arabic",
    "tafqeet",
    "numbers",
    "arabic numbers",
    "arabic-date-tafqeet"
  ],
  "homepage": "https://be.net/komy",
  "license": "MIT",
  "authors": [
		{
		"name": "Mohammed Alkoumi",
		"email": "komy66@gmail.com"
		}
	],
  "require": {
    "php": ">=8.0",
    "ext-intl": "*",
    "illuminate/support": "^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0 || ^10.0 || ^11.0"
  },
  "autoload": {
      "psr-4": {
          "Alkoumi\\LaravelArabicTafqeet\\": "src/"
      }
  },
  "autoload-dev": {
    "psr-4": {
      "Alkoumi\\LaravelArabicTafqeet\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Alkoumi\\LaravelArabicTafqeet\\LaravelArabicTafqeetServiceProvider"
      ],
      "aliases": {
        "Tafqeet": "Alkoumi\\LaravelArabicTafqeet\\Tafqeet"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}